<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    tools:context=".ui.platos.PlatosList">

    <androidx.cardview.widget.CardView
        android:id="@+id/sortingBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="false"
        android:layout_margin="16dp"
        app:cardCornerRadius="170dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/sortingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center"
                android:layout_marginLeft="@dimen/big_padding"
                android:layout_marginRight="@dimen/big_padding"
                android:text="@string/sort_by"
                android:textColor="?attr/colorControlNormal"
                android:textSize="16sp" />

            <Button
                android:id="@+id/buttonSortPlato"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_button"
                android:drawableRight="@drawable/expand_more_24px"
                android:onClick="showSortMenu"
                android:paddingLeft="@dimen/big_padding"
                android:paddingRight="@dimen/small_padding"
                android:text="@string/sort_by_nombre_plato"
                android:textColor="?attr/colorControlNormal"
                android:textAllCaps="false" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>
